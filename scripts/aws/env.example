# Copy to repo root as .env, fill in the NEW-account values, then:
#   set -a; source .env; set +a
#   python sagemaker_submit.py --job pretrain --dry-run
#
# sagemaker_submit.py reads these three from the environment.
AWS_REGION=us-east-2
S3_BUCKET=sagemaker-us-east-2-<NEW_ACCOUNT_ID>
SM_ROLE_ARN=arn:aws:iam::<NEW_ACCOUNT_ID>:role/SJJI-SageMaker-ExecutionRole

# The old account's data bucket — jobs read raw/processed TUH from here
# cross-account. Referenced by the setup scripts, not by sagemaker_submit.py.
OLD_BUCKET=sagemaker-us-east-2-506145782110

# Local CLI profile name you configured for the new account.
AWS_PROFILE=sjji-new
